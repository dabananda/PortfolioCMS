{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost\\SQLEXPRESS;Database=PortfolioCMSDb;Trusted_Connection=True;TrustServerCertificate=Yes;MultipleActiveResultSets=true;"
  },
  "AdminUser": {
    "FirstName": "Admin",
    "LastName": "User"
  },
  "JwtSettings": {
    "Issuer": "PortfolioCMS.Server",
    "Audience": "PortfolioCMS.Client",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "EmailSettings": {
    "FromEmail": "noreply@portfoliocms.com",
    "FromName": "Portfolio CMS",
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "EnableSsl": true
  },
  "IdentitySettings": {
    "RequireConfirmedEmail": true,
    "PasswordRequireDigit": true,
    "PasswordRequireLowercase": true,
    "PasswordRequireUppercase": true,
    "PasswordRequireNonAlphanumeric": true,
    "PasswordRequiredLength": 8,
    "MaxFailedAccessAttempts": 5,
    "LockoutTimeSpanMinutes": 15
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "CorsSettings": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:4200",
      "http://localhost:3000",
      "http://192.168.0.137:3000"
    ]
  },
  "FrontendBaseUrl": "http://localhost:3000"
}